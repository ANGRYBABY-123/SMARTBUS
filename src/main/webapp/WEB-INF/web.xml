<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>CommuteSafe System</display-name>

    <!--
        Google OAuth 2.0 credentials.
        Replace the placeholder values with your real credentials from:
        https://console.cloud.google.com/apis/credentials
        Authorised redirect URI to register: {app-base-url}/oauth/google/callback
    -->
    <context-param>
        <param-name>google.client.id</param-name>
        <param-value>226760208652-61mt2u1vlqg1m0co57v6p3m951srg9ha.apps.googleusercontent.com</param-value>
    </context-param>
    <context-param>
        <param-name>google.client.secret</param-name>
        <param-value>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</param-value>
    </context-param>

    <!--
        Gemini API key for the AI chat assistant.
        Prefer setting the GEMINI_API_KEY environment variable (checked first).
        Only fall back to this param for local development.
    -->
    <context-param>
        <param-name>gemini.api.key</param-name>
        <param-value></param-value>
    </context-param>

    <!-- Default welcome page — routed through DashboardServlet so auth filter applies -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
    </session-config>

    <!-- Shutdown JPA on undeploy -->
    <listener>
        <listener-class>com.smartbus.listener.AppContextListener</listener-class>
    </listener>

    <!-- Error pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error500.jsp</location>
    </error-page>
</web-app>
