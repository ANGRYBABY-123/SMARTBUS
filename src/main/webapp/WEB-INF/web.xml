<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>CommuteSafe System</display-name>

    <!--
        Google OAuth 2.0 credentials.
        Replace the placeholder values with your real credentials from:
        https://console.cloud.google.com/apis/credentials
        Authorised redirect URI to register: {app-base-url}/oauth/google/callback
    -->
    <context-param>
        <param-name>google.client.id</param-name>
        <param-value>226760208652-61mt2u1vlqg1m0co57v6p3m951srg9ha.apps.googleusercontent.com</param-value>
    </context-param>
    <context-param>
        <param-name>google.client.secret</param-name>
        <param-value>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</param-value>
    </context-param>

    <!--
        Gemini API key for the AI chat assistant.
        Prefer setting the GEMINI_API_KEY environment variable (checked first).
        Only fall back to this param for local development.
    -->
    <context-param>
        <param-name>gemini.api.key</param-name>
        <param-value></param-value>
    </context-param>

    <!--
        Google Maps JavaScript API key.
        Get your key from: https://console.cloud.google.com/apis/credentials
        Enable: Maps JavaScript API, Directions API, Places API
        Restrict by HTTP referrer to prevent unauthorised use.
        Can also be set via GOOGLE_MAPS_KEY environment variable.
    -->
    <context-param>
        <param-name>google.maps.key</param-name>
        <param-value>YOUR_GOOGLE_MAPS_API_KEY</param-value>
    </context-param>

    <!--
        Google Analytics 4 – Measurement ID (format: G-XXXXXXXXXX).
        Get it from: https://analytics.google.com → Admin → Data Streams
        Can also be set via GA_MEASUREMENT_ID environment variable.
    -->
    <context-param>
        <param-name>ga.measurement.id</param-name>
        <param-value>YOUR_GA4_MEASUREMENT_ID</param-value>
    </context-param>

    <!--
        Firebase Cloud Messaging (FCM) – Web Push Notifications.
        Get values from Firebase Console → Project Settings → General → Your apps (Web).
        VAPID key: Project Settings → Cloud Messaging → Web Push certificates → Key pair.
        FCM_SERVER_KEY env var should be set to your Firebase service account JSON path
        or the JSON content itself (for Render: upload as secret file).
    -->
    <context-param>
        <param-name>firebase.api.key</param-name>
        <param-value>YOUR_FIREBASE_API_KEY</param-value>
    </context-param>
    <context-param>
        <param-name>firebase.auth.domain</param-name>
        <param-value>YOUR_PROJECT_ID.firebaseapp.com</param-value>
    </context-param>
    <context-param>
        <param-name>firebase.project.id</param-name>
        <param-value>YOUR_FIREBASE_PROJECT_ID</param-value>
    </context-param>
    <context-param>
        <param-name>firebase.messaging.sender.id</param-name>
        <param-value>YOUR_MESSAGING_SENDER_ID</param-value>
    </context-param>
    <context-param>
        <param-name>firebase.app.id</param-name>
        <param-value>YOUR_FIREBASE_APP_ID</param-value>
    </context-param>
    <context-param>
        <param-name>firebase.vapid.key</param-name>
        <param-value>YOUR_VAPID_PUBLIC_KEY</param-value>
    </context-param>

    <!-- Default welcome page — routed through DashboardServlet so auth filter applies -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
    </session-config>

    <!-- Shutdown JPA on undeploy -->
    <listener>
        <listener-class>com.smartbus.listener.AppContextListener</listener-class>
    </listener>

    <!-- Error pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error500.jsp</location>
    </error-page>
</web-app>
